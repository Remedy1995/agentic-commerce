# ============================================================
# NanaBanana Commerce — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Google Gemini API ---
# Nano Banana 2 model: gemini-3.1-flash-image-preview
# Agent text model:    gemini-2.0-flash
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# --- Circle Developer API (https://console.circle.com) ---
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here
CIRCLE_WALLET_SET_ID=your_wallet_set_id_here

# Merchant wallet — address that RECEIVES nanopayments (from Circle DCW)
# Populate after running: npm run setup-wallet
MERCHANT_WALLET_ADDRESS=

# --- Agent wallet (PAYS for image generations) ---
# Regular EOA private key — used by GatewayClient to sign EIP-3009 payments
# Run: npm run setup-wallet  to generate one
AGENT_PRIVATE_KEY=0x_your_agent_eoa_private_key_here
AGENT_WALLET_ADDRESS=

# --- Server ---
PORT=4000
NODE_ENV=development

# --- ARC Testnet (pre-configured — do not change) ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# --- Payment Config ---
# Price per image generation in USD (must be <= $0.01 per hackathon rules)
PRICE_PER_GENERATION=0.001
